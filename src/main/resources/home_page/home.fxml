<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="944.0" prefWidth="1554.0" stylesheets="/home_page/style.css"
            xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pl.pja.edu.s27619.gui_controllers.HomeController">
    <children>
        <VBox fx:id="vBoxContainer" alignment="TOP_CENTER" layoutX="33.0" layoutY="26.0" prefHeight="854.0"
              prefWidth="220.0">
            <children>
                <ImageView fitHeight="160.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@img/profile_icon.png"/>
                    </image>
                </ImageView>
                <Label fx:id="userDetails" alignment="CENTER" contentDisplay="TOP" prefHeight="65.0" prefWidth="224.0"
                       textAlignment="CENTER">
                    <font>
                        <Font name="System Bold" size="16.0"/>
                    </font>
                </Label>
                <Button fx:id="homeButton" alignment="BASELINE_LEFT" focusTraversable="false" graphicTextGap="15.0"
                        mnemonicParsing="false" onMouseClicked="#leftMouseClicked" prefHeight="89.0" prefWidth="225.0"
                        text="Home">
                    <graphic>
                        <ImageView fitHeight="43.0" fitWidth="43.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@img/home_icon.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                    <font>
                        <Font name="System Bold" size="19.0"/>
                    </font>
                </Button>
                <Button fx:id="manageButton" alignment="BASELINE_LEFT" focusTraversable="false" graphicTextGap="15.0"
                        mnemonicParsing="false" onMouseClicked="#leftMouseClicked" prefHeight="89.0" prefWidth="225.0"
                        text="Manage">
                    <graphic>
                        <ImageView fitHeight="43.0" fitWidth="43.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@img/manage_icon.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                    <font>
                        <Font name="System Bold" size="19.0"/>
                    </font>
                </Button>
                <Button fx:id="systemInfoButton" alignment="BASELINE_LEFT" focusTraversable="false"
                        graphicTextGap="15.0" mnemonicParsing="false" onMouseClicked="#leftMouseClicked"
                        prefHeight="89.0" prefWidth="225.0" text="System info">
                    <graphic>
                        <ImageView fitHeight="43.0" fitWidth="43.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@img/system_icon.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                    <font>
                        <Font name="System Bold" size="20.0"/>
                    </font>
                </Button>
                <Button fx:id="shopButton" alignment="BASELINE_LEFT" focusTraversable="false" graphicTextGap="15.0"
                        mnemonicParsing="false" onMouseClicked="#leftMouseClicked" prefHeight="89.0" prefWidth="225.0"
                        text="Shop">
                    <graphic>
                        <ImageView fx:id="sho" fitHeight="43.0" fitWidth="43.0" pickOnBounds="true"
                                   preserveRatio="true">
                            <image>
                                <Image url="@img/store_icon.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                    <font>
                        <Font name="System Bold" size="19.0"/>
                    </font>
                </Button>
                <Button fx:id="logOutButton" alignment="BASELINE_LEFT" focusTraversable="false" graphicTextGap="15.0"
                        mnemonicParsing="false" onMouseClicked="#leftMouseClicked" prefHeight="89.0" prefWidth="225.0"
                        text="Log out">
                    <graphic>
                        <ImageView fitHeight="43.0" fitWidth="43.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@img/log_out_icon.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                    <font>
                        <Font name="System Bold" size="19.0"/>
                    </font>
                </Button>
            </children>
            <cursor>
                <Cursor fx:constant="NONE"/>
            </cursor>
        </VBox>
        <Label layoutX="280.0" layoutY="26.0" prefHeight="55.0" prefWidth="437.0" text="Home page">
            <font>
                <Font name="System Bold" size="42.0"/>
            </font>
        </Label>
    </children>
</AnchorPane>
