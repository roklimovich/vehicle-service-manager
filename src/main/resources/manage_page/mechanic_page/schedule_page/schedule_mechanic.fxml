            <Font name="Century Gothic" size="26.0" />
         </font>
      </Label>
      <DatePicker fx:id="selectDate" layoutX="331.0" layoutY="271.0" onAction="#actionPerformed" prefHeight="46.0" prefWidth="321.0" promptText="Select date" />
      <ComboBox fx:id="servicePicker" layoutX="329.0" layoutY="426.0" prefHeight="42.0" prefWidth="321.0" promptText="Choose service" />
