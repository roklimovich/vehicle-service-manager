                <Font name="Century Gothic" size="42.0" />
            </font>
        </Label>
        <Button fx:id="backButton" layoutX="14.0" layoutY="26.0" mnemonicParsing="false" onMouseClicked="#leftMouseClicked" prefHeight="47.0" prefWidth="92.0" style="-fx-background-color: none;" text="←" textFill="WHITE">
            <font>
                <Font name="Century Gothic" size="29.0" />
            </font>
        </Button>
        <Label layoutX="56.0" layoutY="263.0" prefHeight="74.0" prefWidth="202.0" text="Type" textFill="WHITE">
            <font>
                <Font name="Century Gothic" size="32.0" />
