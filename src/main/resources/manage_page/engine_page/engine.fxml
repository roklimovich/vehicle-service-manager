                <Font name="Century Gothic" size="24.0" />
            </font>
        </Label>
        <Label layoutX="56.0" layoutY="197.0" prefHeight="74.0" prefWidth="244.0" text="Name" textFill="WHITE">
            <font>
                <Font name="Century Gothic" size="32.0" />
            </font>
        </Label>
        <TextField fx:id="engineNameField" layoutX="310.0" layoutY="213.0" prefHeight="42.0" prefWidth="329.0" promptText="Enter engine name">
