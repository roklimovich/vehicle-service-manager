            <font>
                <Font name="Century Gothic" size="24.0" />
            </font>
            <graphic>
                <ImageView fitHeight="56.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@img/checkmark_button.png" />
