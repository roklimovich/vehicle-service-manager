<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- Database connection settings -->
        <property name="connection.driver_class">org.h2.Driver</property>
        <property name="connection.url">jdbc:h2:mem:db1;DB_CLOSE_DELAY=-1</property>
        <!--<property name="connection.url">jdbc:h2:~/db-test.h2</property>-->
        <!--<property name="connection.url">jdbc:h2:tcp://localhost/~/db-test.h2</property>-->
        <property name="connection.username">ro.klimovich</property>
        <property name="connection.password">admin34</property>

        <!-- JDBC connection pool (use the built-in) -->
        <property name="connection.pool_size">1</property>

        <!-- SQL dialect -->
        <property name="dialect">org.hibernate.dialect.H2Dialect</property>

        <!-- Disable the second-level cache  -->
        <!-- <property name="cache.provider_class">org.hibernate.cache.internal.NoCacheProvider</property> -->

        <!-- Echo all executed SQL to stdout -->
        <property name="show_sql">true</property>

        <!--Drop and re-create the database schema on startup-->
        <property name="hbm2ddl.auto">create</property>

        <!-- Enable Hibernate stats in the logs -->
        <property name="hibernate.generate_statistics">false</property>

        <mapping class="pl.pja.edu.s27619.vehicle.component.Engine"/>
        <mapping class="pl.pja.edu.s27619.clients.Client"/>
        <mapping class="pl.pja.edu.s27619.clients.BasicClient"/>
        <mapping class="pl.pja.edu.s27619.clients.VIPClient"/>
        <mapping class="pl.pja.edu.s27619.vehicle.Vehicle"/>
        <mapping class="pl.pja.edu.s27619.vehicle.condition.VehicleCertificate"/>
        <mapping class="pl.pja.edu.s27619.vehicle.repair.ServiceRecord"/>
        <mapping class="pl.pja.edu.s27619.administration.Admin"/>
        <mapping class="pl.pja.edu.s27619.administration.Supervisor"/>
        <mapping class="pl.pja.edu.s27619.warehouse.PartOrder"/>
    </session-factory>
</hibernate-configuration>